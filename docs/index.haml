!!!
%html{lang: lang, dir: dir}
  %head
    %meta{charset: "utf-8"}
    %meta{name: "viewport", content: "width=device-width, initial-scale=1"}
    %title= title
    %link{rel: "preconnect", href: "https://fonts.googleapis.com"}
    %link{rel: "preconnect", href: "https://fonts.gstatic.com", crossorigin: true}
    %link{rel: "stylesheet", href: "https://fonts.googleapis.com/css2?family=Turret+Road:wght@200;300;400;500;700;800&family=Noto+Naskh+Arabic:wght@400;500;600;700&family=Noto+Sans+Devanagari:wght@200;300;400;500;700&display=swap"}
    %link{rel: "stylesheet", href: "#{asset_prefix}/assets/css/style.css"}

  %body
    .hero-bg
    .hero-nemicolopterus
    .hero-overlay

    %nav
      %a.home-link{href: "#", onclick: "majesticScroll(); return false;", title: "Scroll to top — PteronautOS"}= nav_home
      %a{href: "#essence"}= nav_essence
      %a{href: "#architecture"}= nav_architecture
      %a{href: "#zephyrus"}= nav_zephyrus
      %a.gh-link{href: "https://github.com/dantiel/PteronautOS", target: "_blank", title: nav_github}= nav_github
      .lang-switch
        %a{href: lang_href_en, class: lang_class_en} EN
        %a{href: lang_href_pt, class: lang_class_pt} PT
        %a{href: lang_href_ru, class: lang_class_ru} RU
        %a{href: lang_href_es, class: lang_class_es} ES
        %a{href: lang_href_de, class: lang_class_de} DE
        %a{href: lang_href_ja, class: lang_class_ja} 日本語
        %a{href: lang_href_zh, class: lang_class_zh} 中文
        %a{href: lang_href_ar, class: lang_class_ar} عربي
        %a{href: lang_href_hi, class: lang_class_hi} हिन्दी

    %header.hero
      .hero-content
        .headline
          %h1
            %span.pteronaut> PTERONAUT
            %span.os OS
          %p.subhead= hero_subhead
          %p.greeting= hero_greeting
          %pre.glyph
            :preserve
                   ___
                  /    \___
                 /  _     o\___
                /  /  \___  /    \
               |  /   \     \/  _  \
               | /     \    /  / \  |
                \_____/\/  /   \  |
                      /\___/     \ |
                     /
          %p.version= hero_version

    %main
      %section#essence
        %h2
          %span.section-num= essence_num
          = essence_title
        %p.lead!= essence_lead
        %p!= essence_body
        .highlight
          %code= essence_highlight

      %section#architecture
        %h2
          %span.section-num= arch_num
          = arch_title
        %dl.grid
          %dt= arch_ornithopter_title
          %dd= arch_ornithopter_desc
          %dt= arch_zephyrus_title
          %dd= arch_zephyrus_desc
          %dt= arch_servo_title
          %dd= arch_servo_desc
          %dt= arch_target_title
          %dd= arch_target_desc

      %section#zephyrus
        %h2
          %span.section-num= zeph_num
          = zeph_title
        %p.lead= zeph_lead
        %table.specs
          %tr
            %td= zeph_sensor_label
            %td= zeph_sensor_val
          %tr
            %td= zeph_interface_label
            %td= zeph_interface_val
          %tr
            %td= zeph_ahrs_label
            %td= zeph_ahrs_val
          %tr
            %td= zeph_pid_label
            %td= zeph_pid_val
          %tr
            %td= zeph_output_label
            %td= zeph_output_val
          %tr
            %td= zeph_ram_label
            %td.value= zeph_ram_val
          %tr
            %td= zeph_flash_label
            %td.value= zeph_flash_val
        %p.doc-link
          %a{ href: "https://github.com/dantiel/PteronautOS/blob/master/src/lib/Zephyrus/README.md" }= zeph_readme_link

      %section.build
        %h2
          %span.section-num= build_num
          = build_title
        %pre
          %code= build_line
        %p.compatible= build_compatible

    %footer
      %p= footer_hermetic
      %p.credit= footer_credit

    %button.scroll-top{onclick: "window.scrollTo({top:0,behavior:'smooth'})", "aria-label": "Scroll to top"}

    :javascript
      const hero = document.querySelector('.hero-content');
      const creature = document.querySelector('.hero-nemicolopterus');
      const overlay = document.querySelector('.hero-overlay');
      const nav = document.querySelector('nav');
      const scrollBtn = document.querySelector('.scroll-top');

      function majesticScroll() {
        const start = window.scrollY;
        const duration = 1500;
        const startTime = performance.now();

        function step(now) {
          const elapsed = now - startTime;
          const t = Math.min(elapsed / duration, 1);
          // Ease-out quintic — majestic deceleration
          const eased = 1 - Math.pow(1 - t, 4);
          window.scrollTo(0, start * (1 - eased));
          if (t < 1) requestAnimationFrame(step);
        }

        requestAnimationFrame(step);
      }

      function tick() {
        const scroll = window.scrollY;
        const vh = window.innerHeight;
        const t = Math.min(scroll / vh, 1);

        hero.style.setProperty('--scroll', t.toFixed(3));
        hero.style.opacity = 1 - t * 0.6;

        const py = t * 110;  // land down
        creature.style.transform = `translateY(${py}%)`;
        creature.style.opacity = Math.max(0, 1 - t * 1.4);  // fade out wingtips

        overlay.style.opacity = Math.min(t * 0.85, 0.85);

        nav.classList.toggle('scrolled', scroll > 40);

        scrollBtn.classList.toggle('visible', scroll > vh * 0.6);

        requestAnimationFrame(tick);
      }

      requestAnimationFrame(tick);