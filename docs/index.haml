!!!
%html{lang: "en"}
  %head
    %meta{charset: "utf-8"}
    %meta{name: "viewport", content: "width=device-width, initial-scale=1"}
    %title PteronautOS
    %link{rel: "preconnect", href: "https://fonts.googleapis.com"}
    %link{rel: "preconnect", href: "https://fonts.gstatic.com", crossorigin: true}
    %link{rel: "stylesheet", href: "https://fonts.googleapis.com/css2?family=Turret+Road:wght@400;700;800&display=swap"}
    %link{rel: "stylesheet", href: "assets/css/style.css"}

  %body
    .hero-bg
    .hero-nemicolopterus
    .hero-overlay

    %nav
      %a{href: "#essence"}> Essence
      %a{href: "#architecture"}> Architecture
      %a{href: "#zephyrus"}> Zephyrus
      %a{href: "https://github.com/paraeksperiment/PteronautOS"}> GitHub

    %header.hero
      .hero-content
        %h1.headline
          %span.pteronaut> PTERONAUT
          %span.os OS
        %p.subhead Fly Natural. Control Precise.
        %pre.glyph
          :preserve
                 ___
                /   \___
               /  _     o\___
              /  / \___  /   \
             |  /  \   \/  _  \
             | /    \  /  / \  |
              \______/\/  /   \ |
                    /\___/     \|
                   /
        %p.version ExpressLRS fork · ESP8285 · CRSF protocol

    %main
      %section#essence
        %h2 Essence
        %p
          O PteronautOS é um <strong>fork do ExpressLRS</strong> transformado
          em controlador de voo para ornitóptero. Não é um quad — não há motores,
          nem ESC, nem Betaflight. O movimento é gerado por <strong>forma de onda</strong>
          que pilota dois servos de asa e um servo de leme.

        .highlight
          %code CRSF (rádio) → rx_main → Ornithopter → waveform → PWM servos

      %section#architecture
        %h2 Architecture

        %dl.grid
          %dt> Ornithopter
          %dd> Mixer, waveform generation, channel filtering

          %dt> Zephyrus
          %dd> MPU6050 gyroscope + Mahony AHRS + dual PID

          %dt> ServoOutput
          %dd> PWM synchronized to CRSF tick

          %dt> Target
          %dd> ESP8285 2400MHz RX

      %section#zephyrus
        %h2 Zephyrus Gyro Module

        %p
          Estabilização do leme de crista cefálica via MPU6050.
          Mahony AHRS para estimativa de atitude, dual PID para
          correção de roll angle e yaw rate.

        %table.specs
          %tr
            %td> Sensor
            %td> MPU6050 (GY-521)
          %tr
            %td> Interface
            %td> I2C directo (GPIO4/5)
          %tr
            %td> AHRS
            %td> Mahony (registo a registo, ~1kHz)
          %tr
            %td> PID
            %td> Duplo: roll angle + yaw rate
          %tr
            %td> Output
            %td> Correção ao leme de crista
          %tr
            %td> RAM
            %td> ~62% (margem reservada)
          %tr
            %td> Flash
            %td> ~56% (conservativo)

      %section.build
        %h2 Build
        %pre
          %code pio run -e PteronautOS_ESP8285_2400_RX

        %p.compatible
          Compatível: ExpressLRS TX 2.4GHz · Baudrate: 420000

    %footer
      %p
        Hermetic firmware · 80MHz · 1MB Flash · Zero dependencies
      %p.credit
        Fork do ExpressLRS 4.x · projecto <a href="https://github.com/paraeksperiment">paraeksperiment</a>

    :javascript
      const hero = document.querySelector('.hero-content');
      const bg = document.querySelector('.hero-bg');
      const creature = document.querySelector('.hero-nemicolopterus');
      const overlay = document.querySelector('.hero-overlay');

      function tick() {
        const scroll = window.scrollY;
        const vh = window.innerHeight;
        const t = Math.min(scroll / vh, 1);

        hero.style.setProperty('--scroll', t.toFixed(3));
        hero.style.opacity = 1 - t * 0.6;

        // Subtle parallax on creature layer
        const py = 20 + t * 8;
        creature.style.transform = `translateY(${py}%)`;

        // Gradient overlay intensifies with scroll
        overlay.style.opacity = Math.min(t * 0.7, 0.7);

        requestAnimationFrame(tick);
      }

      requestAnimationFrame(tick);
